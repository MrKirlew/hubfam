{
  "expo": {
    "name": "Family Hub",
    "slug": "family-hub",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080c18",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080c18"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familyhub.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Family Hub reads your calendar events to display them on the hub.",
        "NSRemindersUsageDescription": "Family Hub can create reminders for upcoming events."
      }
    },
    "android": {
      "package": "com.familyhub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080c18"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#60a5fa",
          "sounds": ["./assets/notification.wav"]
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
