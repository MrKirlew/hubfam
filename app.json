{
  "expo": {
    "name": "Family Hub",
    "slug": "family-hub",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080c18",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080c18"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familyhub.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Family Hub reads your calendar events to display them on the hub.",
        "NSRemindersUsageDescription": "Family Hub can create reminders for upcoming events."
      }
    },
    "android": {
      "package": "com.familyhub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080c18"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#080c18",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#60a5fa",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-audio",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 31,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fca13b06-f831-4ffd-bb75-9442656d8e97"
      },
      "privacyPolicyUrl": "https://mrkirlew.github.io/hubfam/"
    },
    "owner": "mrkirlew"
  }
}
