# .easignore overrides .gitignore for EAS Build project uploads.
# We intentionally do NOT ignore /android and /ios here — EAS needs the native
# projects to build. .gitignore ignores them because CNG regenerates them, but
# the EAS pipeline uses the committed/tracked native code.

# Environment variables — never upload local .env (EAS injects its own)
.env
.env.local
.env.production

# Node
node_modules/

# Expo
.expo/

# Android build outputs
android/app/build/
android/.gradle/
android/build/

# iOS
ios/Pods/
ios/build/

# Companion app (apps/companion) — CNG/managed: its android/ and ios/ dirs are
# git-untracked and regenerated by EAS Prebuild in the cloud. The local prebuild
# is ~1.7 GB; uploading a stale local android/ (with absolute paths + build
# intermediates) caused EAS_BUILD_UNKNOWN_GRADLE_ERROR on cloud builds (DEBT-047).
# NOTE: a .easignore fully replaces .gitignore, so these already-gitignored dirs
# must be re-listed here or they get swept into the EAS upload.
apps/companion/android/
apps/companion/ios/

# OS files
.DS_Store
Thumbs.db

# Google service credentials — never upload local copies
droidgoogser.json
webgserv.json
google-services.json

# Dev screenshots (loose files in project root only — not inside android/ios)
/*.png

# Play Store signing key — EAS has its own keystore
*.keystore
*.jks
play-store-key.json

# Internal team framework — private docs, not needed for build
PROJECT_SUMMARY_PART*.md
CLAUDE.md
.claude-team/
PROJECT_SUMMARY_P*.md
DECISION_LOG*.md
TECH_DEBT*.md
init.sh
scan.sh
inspect.sh
