{
  "expo": {
    "name": "Family Hub Remote",
    "slug": "family-hub-remote",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "familyhubremote",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#080c18"
    },
    "android": {
      "package": "com.familyhub.companion"
    },
    "ios": {
      "bundleIdentifier": "com.familyhub.companion",
      "supportsTablet": true
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Family Hub Remote uses the camera to scan the hub's pairing QR code." }
      ]
    ],
    "extra": {
      "eas": { "projectId": "" }
    }
  }
}
