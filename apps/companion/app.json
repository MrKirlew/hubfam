{
  "expo": {
    "name": "Family Hub Remote",
    "slug": "family-hub-remote",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "familyhubremote",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#080c18"
    },
    "android": {
      "package": "com.familyhub.companion",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.levarkirlew.familyhub.companion",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Family Hub Remote uses the camera to scan the hub's pairing QR code."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true,
          "bluetoothAlwaysPermission": "Family Hub Remote uses Bluetooth to talk to your family hub when it's nearby."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f87cbe20-ae70-49bd-8651-99b85ce2b67a"
      }
    },
    "owner": "mrkirlew"
  }
}
