# Google OAuth credentials — get from Google Cloud Console
# Mobile apps use the Google Sign-In SDK for token management (no client secret needed)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Sentry crash reporting — get DSN from sentry.io project settings
# Leave blank to disable crash reporting in development
EXPO_PUBLIC_SENTRY_DSN=

# Companion-messaging relay (Cloudflare Worker, relay-worker/) — the hub embeds
# this URL in pairing QR codes, so companions inherit it at pair time.
# Leave blank to disable Family Sharing.
EXPO_PUBLIC_RELAY_URL=https://your-relay.your-account.workers.dev
